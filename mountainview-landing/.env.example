# ====================================================
# Resend API Key — لإرسال الليدز على الإيميل
# ====================================================
# 1. روح على https://resend.com وعمل حساب مجاناً
# 2. من Dashboard اضغط "API Keys" → "Create API Key"
# 3. انسخ الـ key وحطه هنا
# 4. غير اسم الملف من .env.example لـ .env.local

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
